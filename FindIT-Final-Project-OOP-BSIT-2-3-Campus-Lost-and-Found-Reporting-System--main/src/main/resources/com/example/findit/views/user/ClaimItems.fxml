<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="420.0" prefWidth="720.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.findit.controllers.user.ClaimItemsController">
   <children>
      <VBox layoutX="40.0" layoutY="35.0" prefHeight="350.0" prefWidth="640.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 18;" AnchorPane.bottomAnchor="35.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="35.0">
         <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
         </padding>
         <children>
            
            <Label text="Claim Item" textFill="#800000">
               <font> <Font name="System Bold" size="24.0" /> </font>
            </Label>
            <Label text="Please provide your details and proof of ownership for this item" textFill="#555555">
               <font> <Font size="13.0" /> </font>
               <VBox.margin> <Insets top="2.0" /> </VBox.margin>
            </Label>
            <HBox spacing="30.0" VBox.vgrow="ALWAYS">
               <VBox.margin> <Insets top="20.0" /> </VBox.margin>
               <children>
                  
                  <VBox prefWidth="280.0" spacing="12.0" HBox.hgrow="ALWAYS">
                     <children>
                        <VBox spacing="4.0">
                           <children>
                              <HBox>
                                 <children>
                                    <Label text="Claimant Name " textFill="#333333"><font><Font name="System Bold" size="12.0" /></font></Label>
                                    <Label text="*" textFill="RED" />
                                 </children>
                              </HBox>
                              <TextField fx:id="txtClaimantName" promptText="Full name" prefHeight="35.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #CCCCCC; -fx-border-radius: 5;" />
                           </children>
                        </VBox>
                        <VBox spacing="4.0">
                           <children>
                              <HBox>
                                 <children>
                                    <Label text="Contact Information " textFill="#333333"><font><Font name="System Bold" size="12.0" /></font></Label>
                                    <Label text="*" textFill="RED" />
                                 </children>
                              </HBox>
                              <TextField fx:id="txtContact" promptText="Email or phone number" prefHeight="35.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #CCCCCC; -fx-border-radius: 5;" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  
                  <VBox prefWidth="280.0" spacing="4.0" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox>
                           <children>
                              <Label text="Proof Description " textFill="#333333"><font><Font name="System Bold" size="12.0" /></font></Label>
                              <Label text="*" textFill="RED" />
                           </children>
                        </HBox>
                        <TextArea fx:id="txtProofDescription" promptText="Describe how you can prove this item belongs to you..." wrapText="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #CCCCCC; -fx-border-radius: 5;" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <HBox spacing="20.0" prefHeight="45.0">
               <VBox.margin> <Insets top="25.0" /> </VBox.margin>
               <children>
                  <Button mnemonicParsing="false" onAction="#handleSubmit" prefHeight="42.0" prefWidth="285.0" style="-fx-background-color: #800000; -fx-background-radius: 8; -fx-cursor: hand;" text="Submit Claim" textFill="WHITE" HBox.hgrow="ALWAYS">
                     <font> <Font name="System Bold" size="14.0" /> </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="42.0" prefWidth="285.0" style="-fx-background-color: #CCCCCC; -fx-background-radius: 8; -fx-cursor: hand;" text="Cancel" textFill="#333333" HBox.hgrow="ALWAYS">
                     <font> <Font name="System Bold" size="14.0" /> </font>
                  </Button>
               </children>
            </HBox>
            
         </children>
      </VBox>
   </children>
</AnchorPane>
