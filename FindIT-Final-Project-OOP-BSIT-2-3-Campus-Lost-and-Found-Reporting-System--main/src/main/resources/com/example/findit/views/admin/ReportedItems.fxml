<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="1000.0" style="-fx-background-color: #F5F5F7;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.findit.controllers.admin.ReportedItemsController">
   
   <left>
      <fx:include source="AdminDashboardSidebar.fxml" fx:id="sidebar" />
   </left>
   
   <center>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <!-- TOP MAROON HEADER WITH LIVE TIMESTAMP -->
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: #800000; -fx-padding: 0 30 0 0;">
               <children>
                  <Label text="Reports" textFill="#FFCC00">
                     <font><Font name="System Bold" size="26.0" /></font>
                     <HBox.margin><Insets left="30.0" /></HBox.margin>
                  </Label>
                  
                  <!-- Spacer to push the clock to the far right -->
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <!-- Live Timestamp Label -->
                  <Label fx:id="lblTimestamp" text="Loading time..." textFill="WHITE">
                     <font><Font name="System Bold" size="14.0" /></font>
                  </Label>
               </children>
            </HBox>
            
            <VBox spacing="20.0" VBox.vgrow="ALWAYS">
               <padding><Insets bottom="25.0" left="30.0" right="30.0" top="25.0" /></padding>
               <children>
                  
                  <!-- FILTER BAR -->
                  <HBox alignment="CENTER_LEFT" prefHeight="75.0" spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 8, 0, 0, 4);">
                     <padding><Insets left="20.0" right="20.0" /></padding>
                     <children>
                        <TextField fx:id="searchField" prefHeight="38.0" promptText="Search reports ..." style="-fx-background-color: #FFFFFF; -fx-border-color: #CCCCCC; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="typeFilter" prefHeight="38.0" prefWidth="130.0" promptText="Type" style="-fx-background-color: #FFFFFF; -fx-border-color: #CCCCCC; -fx-border-radius: 8;" />
                        <ComboBox fx:id="statusFilter" prefHeight="38.0" prefWidth="145.0" promptText="Status" style="-fx-background-color: #FFFFFF; -fx-border-color: #CCCCCC; -fx-border-radius: 8;" />
                        <ComboBox fx:id="dateFilter" prefHeight="38.0" prefWidth="150.0" promptText="Date" style="-fx-background-color: #FFFFFF; -fx-border-color: #CCCCCC; -fx-border-radius: 8;" />
                        <DatePicker fx:id="monthPicker" prefHeight="38.0" prefWidth="145.0" promptText="Month" />
                        <Button mnemonicParsing="false" onAction="#handleShowMatchSuggestions" prefHeight="38.0" prefWidth="190.0" style="-fx-background-color: #FFCC00; -fx-background-radius: 8; -fx-cursor: hand; -fx-text-fill: #4A1212; -fx-font-weight: bold;" text="Match Suggestions" />
                        <Button fx:id="archivedItemsButton" mnemonicParsing="false" onAction="#handleToggleArchivedItems" prefHeight="38.0" prefWidth="185.0" style="-fx-background-color: #800000; -fx-background-radius: 8; -fx-cursor: hand; -fx-text-fill: #FFFFFF; -fx-font-weight: bold;" text="Archived Reports" />
                     </children>
                  </HBox>
                  
                  <!-- TABLE CONTAINER -->
                  <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" VBox.vgrow="ALWAYS">
                     <children>
                        <TableView fx:id="reportsTable" style="-fx-background-color: transparent; -fx-base: #FFFFFF;" VBox.vgrow="ALWAYS">
                          <columns>
                              <TableColumn fx:id="colReportStatus" prefWidth="115.0" text="Status" />
                              <TableColumn fx:id="colClaimTrackingId" prefWidth="125.0" text="Claim ID" />
                              <TableColumn fx:id="colItemTrackingId" prefWidth="125.0" text="Item ID" />
                              <TableColumn fx:id="colItemName" prefWidth="140.0" text="Item Name" />
                              <TableColumn fx:id="colType" prefWidth="115.0" text="Report Kind" />
                              <TableColumn fx:id="colCategory" prefWidth="110.0" text="Category" />
                              <TableColumn fx:id="colDate" prefWidth="105.0" text="Date" />
                              <TableColumn fx:id="colClaimant" prefWidth="140.0" text="Reporter / Claimant" />
                              <TableColumn fx:id="colLocation" prefWidth="130.0" text="Location" />
                              <TableColumn fx:id="colAction" prefWidth="180.0" text="Action" />
                          </columns>
                           <VBox.margin><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></VBox.margin>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>
